rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Permitir a usuarios autenticados leer y escribir la colección de usuarios
    // Esto es necesario para que el modal de Gestión de Usuarios pueda cargar la lista
    match /users/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
